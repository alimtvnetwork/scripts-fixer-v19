{
  "_comment": "Script 64 -- WindowsTerminal right-click context menu. 'Open Here' (no elevation) is listed first; 'Open as Admin' second (UAC via Start-Process -Verb RunAs).",
  "enabled": true,
  "menu": {
    "parentKeyName": "WindowsTerminalMenu",
    "parentLabel": "WindowsTerminal",
    "iconMode": "wt"
  },
  "modes": {
    "normal": {
      "contextMenuLabel": "Open Here",
      "registryPaths": {
        "directory":  "Registry::HKEY_CLASSES_ROOT\\Directory\\shell\\WindowsTerminalMenu\\shell\\01-OpenHere",
        "background": "Registry::HKEY_CLASSES_ROOT\\Directory\\Background\\shell\\WindowsTerminalMenu\\shell\\01-OpenHere"
      },
      "commandArgs": {
        "directory":  "\"{exe}\" -Dir \"%V\"",
        "background": "\"{exe}\" -Dir \"%V\""
      }
    },
    "admin": {
      "contextMenuLabel": "Open as Admin",
      "registryPaths": {
        "directory":  "Registry::HKEY_CLASSES_ROOT\\Directory\\shell\\WindowsTerminalMenu\\shell\\02-OpenAsAdmin",
        "background": "Registry::HKEY_CLASSES_ROOT\\Directory\\Background\\shell\\WindowsTerminalMenu\\shell\\02-OpenAsAdmin"
      },
      "commandArgs": {
        "directory":  "powershell.exe -NoProfile -Command \"Start-Process -FilePath '{exe}' -Verb RunAs -ArgumentList '-Dir','%V'\"",
        "background": "powershell.exe -NoProfile -Command \"Start-Process -FilePath '{exe}' -Verb RunAs -ArgumentList '-Dir','%V'\""
      },
      "runas": true,
      "extended": false
    }
  },
  "enabledModes": ["normal", "admin"],
  "wtPaths": {
    "programFiles":      "C:\\Program Files\\WindowsTerminal\\wt.exe",
    "programFilesX86":   "C:\\Program Files (x86)\\WindowsTerminal\\wt.exe",
    "chocoShim":         "%ProgramData%\\chocolatey\\bin\\wt.exe",
    "chocoToolsRoot":    "%ProgramData%\\chocolatey\\lib\\wt\\tools\\WindowsTerminalPack",
    "userLocalAppData":  "%LOCALAPPDATA%\\WindowsTerminal\\wt.exe"
  },
  "verifyCommand": "wt",
  "versionFlag": "-version",
  "fallbackTo32Bit": true
}
