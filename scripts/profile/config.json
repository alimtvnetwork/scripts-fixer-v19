{
  "_comment": "Profile recipes -- declarative install pipelines. Each step has a 'kind' field. Supported kinds: 'script' (registry id + optional mode), 'choco' (direct choco install), 'subcommand' (root-level: e.g. 'os hib-off'), 'inline' (helper function name in shared/profile-inline.ps1), 'profile' (recursive expansion -- cycle detected at runtime).",
  "profiles": {
    "minimal": {
      "label": "Minimal Bootstrap",
      "description": "Quick fresh-Windows bootstrap: choco + git + 7zip + chrome + Ubuntu font + Win11 classic right-click menu.",
      "steps": [
        { "kind": "script",     "id": 2,  "label": "Chocolatey package manager" },
        { "kind": "script",     "id": 7,  "label": "Git + LFS" },
        { "kind": "choco",      "package": "7zip.install", "label": "7-Zip archiver" },
        { "kind": "choco",      "package": "googlechrome", "label": "Google Chrome" },
        { "kind": "script",     "id": 47, "label": "Ubuntu font" },
        { "kind": "inline",     "function": "Restore-Win11ClassicContext", "label": "Win11 classic right-click menu" }
      ]
    },
    "base": {
      "label": "Base Windows Setup",
      "description": "Standard daily-driver Windows install: package managers + media + browser + terminal + editor.",
      "steps": [
        { "kind": "script",     "id": 2,  "label": "Chocolatey package manager" },
        { "kind": "script",     "id": 7,  "label": "Git + LFS" },
        { "kind": "choco",      "package": "vlc",                    "label": "VLC media player" },
        { "kind": "choco",      "package": "7zip.install",           "label": "7-Zip archiver" },
        { "kind": "choco",      "package": "winrar",                 "label": "WinRAR archiver" },
        { "kind": "script",     "id": 47, "label": "Ubuntu font" },
        { "kind": "choco",      "package": "xmind",                  "label": "XMind mind-mapper" },
        { "kind": "script",     "id": 33, "mode": "install+settings", "label": "Notepad++ + settings" },
        { "kind": "choco",      "package": "googlechrome",           "label": "Google Chrome" },
        { "kind": "script",     "id": 48, "mode": "install+settings", "label": "ConEmu + settings" },
        { "kind": "subcommand", "path": "os hib-off",                "label": "Disable hibernation" },
        { "kind": "inline",     "function": "Install-PSReadLineLatest", "label": "PSReadLine (latest)" }
      ]
    },
    "git-compact": {
      "label": "Git Compact Install",
      "description": "Git + GitHub Desktop + SSH key + GitHub default dir + opinionated git config.",
      "steps": [
        { "kind": "script",     "id": 7,  "label": "Git + LFS" },
        { "kind": "script",     "id": 8,  "label": "GitHub Desktop" },
        { "kind": "inline",     "function": "Setup-SshKey",            "label": "SSH key (ed25519)" },
        { "kind": "inline",     "function": "Setup-GitHubDir",         "label": "Default GitHub directory" },
        { "kind": "inline",     "function": "Apply-DefaultGitConfig",  "label": "Default git config" }
      ]
    },
    "advance": {
      "label": "Advance Setup",
      "description": "base + git-compact + extras (WordWeb, Beyond Compare, OBS, WhatsApp, VSCode + settings).",
      "steps": [
        { "kind": "profile",    "name": "base" },
        { "kind": "profile",    "name": "git-compact" },
        { "kind": "choco",      "package": "wordweb-free",            "label": "WordWeb dictionary" },
        { "kind": "choco",      "package": "beyondcompare",           "label": "Beyond Compare" },
        { "kind": "script",     "id": 36, "mode": "install+settings", "label": "OBS + settings" },
        { "kind": "script",     "id": 49, "label": "WhatsApp Desktop" },
        { "kind": "script",     "id": 1,  "label": "VS Code" },
        { "kind": "script",     "id": 11, "label": "VS Code settings sync" }
      ]
    },
    "cpp-dx": {
      "label": "C++ + DirectX",
      "description": "VC++ runtimes, DirectX runtime, DirectX SDK -- all OS-dir.",
      "steps": [
        { "kind": "choco",      "package": "vcredist-all",            "label": "VC++ Redistributables (all)" },
        { "kind": "choco",      "package": "directx",                 "label": "DirectX runtime" },
        { "kind": "choco",      "package": "directx-sdk",             "label": "DirectX SDK" }
      ]
    },
    "small-dev": {
      "label": "Small Dev",
      "description": "advance + Go. Tight everyday dev box -- adds only the Go runtime on top of advance.",
      "steps": [
        { "kind": "profile",    "name": "advance" },
        { "kind": "script",     "id": 6,  "label": "Go (Golang)" }
      ]
    },
    "dev": {
      "label": "Dev",
      "description": "small-dev + Python/pip + Node.js (incl. Yarn + Bun) + pnpm + Rust + PHP. Polyglot daily-driver dev box.",
      "steps": [
        { "kind": "profile",    "name": "small-dev" },
        { "kind": "script",     "id": 5,  "label": "Python + pip" },
        { "kind": "script",     "id": 3,  "label": "Node.js + Yarn + Bun" },
        { "kind": "script",     "id": 4,  "label": "pnpm" },
        { "kind": "script",     "id": 44, "label": "Rust (rustup + cargo)" },
        { "kind": "script",     "id": 16, "label": "PHP" }
      ]
    },
    "dev-advance": {
      "label": "Dev Advance",
      "description": "dev + C# (.NET SDK) + C++/DirectX runtime + SDK. Full polyglot + native stack.",
      "steps": [
        { "kind": "profile",    "name": "dev" },
        { "kind": "script",     "id": 39, "label": ".NET SDK (C#)" },
        { "kind": "profile",    "name": "cpp-dx" }
      ]
    }
  },
  "modeEnvVars": {
    "33": "NPP_MODE",
    "16": "PHP_MODE",
    "36": "OBS_MODE",
    "37": "WT_MODE",
    "32": "DBEAVER_MODE",
    "38": "FLUTTER_MODE",
    "39": "DOTNET_MODE",
    "40": "JAVA_MODE",
    "41": "PYTHON_LIBS_MODE",
    "48": "CONEMU_MODE",
    "50": "ONENOTE_MODE"
  },
  "execution": {
    "stopOnFailure": false,
    "skipChocoIfMissing": false
  }
}
