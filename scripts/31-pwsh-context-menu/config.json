{
  "enabled": true,
  "menu": {
    "parentKeyName": "PowerShellMenu",
    "parentLabel": "PowerShell",
    "iconMode": "pwsh"
  },
  "modes": {
    "normal": {
      "contextMenuLabel": "Open Here",
      "registryPaths": {
        "directory": "Registry::HKEY_CLASSES_ROOT\\Directory\\shell\\PowerShellMenu\\shell\\01-OpenHere",
        "background": "Registry::HKEY_CLASSES_ROOT\\Directory\\Background\\shell\\PowerShellMenu\\shell\\01-OpenHere"
      },
      "commandArgs": {
        "directory": "\"{exe}\" -NoExit -NoProfile -Command \"Set-Location -LiteralPath '%V'\"",
        "background": "\"{exe}\" -NoExit -NoProfile -Command \"Set-Location -LiteralPath '%V'\""
      }
    },
    "admin": {
      "contextMenuLabel": "Open as Admin",
      "registryPaths": {
        "directory": "Registry::HKEY_CLASSES_ROOT\\Directory\\shell\\PowerShellMenu\\shell\\02-OpenAsAdmin",
        "background": "Registry::HKEY_CLASSES_ROOT\\Directory\\Background\\shell\\PowerShellMenu\\shell\\02-OpenAsAdmin"
      },
      "commandArgs": {
        "directory": "\"{exe}\" -NoProfile -Command \"Start-Process -FilePath '{exe}' -Verb RunAs -ArgumentList '-NoExit','-NoProfile','-Command',\\\"Set-Location -LiteralPath '%V'\\\"\"",
        "background": "\"{exe}\" -NoProfile -Command \"Start-Process -FilePath '{exe}' -Verb RunAs -ArgumentList '-NoExit','-NoProfile','-Command',\\\"Set-Location -LiteralPath '%V'\\\"\""
      },
      "runas": true,
      "extended": false
    }
  },
  "enabledModes": ["normal", "admin"],
  "pwshPaths": {
    "programFiles": "C:\\Program Files\\PowerShell\\{major}\\pwsh.exe",
    "winget": "%LOCALAPPDATA%\\Microsoft\\WindowsApps\\pwsh.exe",
    "legacy": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"
  },
  "verifyCommand": "pwsh",
  "versionFlag": "--version",
  "fallbackToLegacy": true
}
